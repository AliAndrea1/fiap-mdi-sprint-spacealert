{
  "expo": {
    "name": "SpaceAlert",
    "slug": "spacealert-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "spacealert",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f3460"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.com.fiap.spacealert"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f3460"
      },
      "package": "br.com.fiap.spacealert"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}